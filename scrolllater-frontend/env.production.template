# ScrollLater Production Environment Variables
# Copy this file to .env.production.local and fill in your values

# ============================================
# CORE CONFIGURATION
# ============================================

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth Configuration (Required)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Integration - OpenRouter (Required)
OPENROUTER_API_KEY=your-openrouter-api-key
NEXT_PUBLIC_OPENROUTER_API_KEY=your-openrouter-api-key

# App Configuration (Required)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_NAME=ScrollLater
NODE_ENV=production

# ============================================
# PERFORMANCE OPTIMIZATIONS (Recommended)
# ============================================

# Upstash Redis for Caching & Rate Limiting
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Cron Job Security
CRON_SECRET=your-secure-cron-secret

# ============================================
# MONITORING & ANALYTICS (Optional)
# ============================================

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# Vercel Analytics (Automatic when deployed on Vercel)
# No configuration needed - automatically enabled

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# CDN & EDGE CONFIGURATION (Optional)
# ============================================

# Cloudflare Integration
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# ============================================
# MULTI-REGION DEPLOYMENT (Optional)
# ============================================

# Primary Region (US East)
PRIMARY_REGION=iad1

# Secondary Region (EU West)
SECONDARY_REGION=lhr1

# Database Read Replicas
SUPABASE_READ_REPLICA_URL=https://read-replica.supabase.co

# ============================================
# COST OPTIMIZATION SETTINGS
# ============================================

# Rate Limiting (requests per minute)
RATE_LIMIT_GENERAL=60
RATE_LIMIT_AI=10
RATE_LIMIT_AUTH=5
RATE_LIMIT_BATCH=5

# AI Cost Limits (in cents)
AI_DAILY_COST_LIMIT=100
AI_MONTHLY_COST_LIMIT=2000

# Cache TTL Settings (in seconds)
CACHE_TTL_SESSION=600
CACHE_TTL_ENTRIES=300
CACHE_TTL_ANALYSIS=3600
CACHE_TTL_PROFILE=1800

# ============================================
# DEVELOPMENT & TESTING
# ============================================

# Feature Flags
ENABLE_CACHE=true
ENABLE_RATE_LIMIT=true
ENABLE_COST_TRACKING=true
ENABLE_MULTI_REGION=false
ENABLE_DEBUG_LOGGING=false

# ============================================
# VERCEL DEPLOYMENT
# ============================================

# These are set automatically by Vercel, but included for reference
VERCEL_URL=
VERCEL_ENV=
VERCEL_REGION=
VERCEL_GIT_COMMIT_SHA=
VERCEL_GIT_COMMIT_MESSAGE=

# ============================================
# NOTES
# ============================================
# 
# 1. Required variables must be set for the app to function
# 2. Recommended variables significantly improve performance
# 3. Optional variables enable additional features
# 4. Never commit this file with actual values to version control
# 5. Use Vercel's environment variable UI for production values
# 6. Rotate all secrets regularly (monthly recommended)
# 7. Monitor usage and costs through respective dashboards
#
# For setup instructions, see: docs/infrastructure-optimization.md